# NexusEdge Production Environment
# Copy to .env on your deployment host and fill every [REQUIRED] value.
# Never commit real secrets to git.

NODE_ENV=production

# ─── Database (Supabase) ───────────────────────────────────────────────────
# [REQUIRED] Use connection pooler (6543) for app runtime; direct (5432) for migrations.
DATABASE_PROVIDER=supabase
SUPABASE_PROJECT_REF=[YOUR_PROJECT_REF]

DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require

# [REQUIRED] Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR_ANON_KEY]
SUPABASE_SERVICE_ROLE_KEY=[YOUR_SERVICE_ROLE_KEY]

# ─── Auth ────────────────────────────────────────────────────────────────────
# [REQUIRED] Generate: openssl rand -base64 48
NEXTAUTH_URL=https://your-domain.example.com
NEXTAUTH_SECRET=[GENERATE_48_BYTE_SECRET]
JWT_SECRET=[GENERATE_DIFFERENT_48_BYTE_SECRET]

# ─── App URLs ────────────────────────────────────────────────────────────────
# Leave unset in production to use same-origin /api, or set your public API base.
# NEXT_PUBLIC_API_URL=https://your-domain.example.com/api

# ─── AI (Ollama on GPU host or LAN) ──────────────────────────────────────────
# [REQUIRED] Ollama must be reachable from the app server.
MODEL_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama-host:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_MODEL_REASONING=deepseek-r1:8b
OLLAMA_TIMEOUT_MS=120000
OLLAMA_MAX_RETRIES=3
OLLAMA_ENABLE_THINKING=false
PROMPT_VERSION=v2

# Optional cloud fallbacks
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VLLM_BASE_URL=
VLLM_MODEL=

# ─── Code execution (Judge0) ─────────────────────────────────────────────────
# [REQUIRED] Judge0 is required when NODE_ENV=production (or set JUDGE0_REQUIRE=true).
JUDGE0_URL=http://judge0-host:2358
JUDGE0_API_KEY=
JUDGE0_REQUIRE=true

# ─── Queue / cache [RECOMMENDED for ECS multi-instance] ─────────────────────
REDIS_URL=redis://redis-host:6379
AGENT_CACHE_ENABLED=true
AGENT_CACHE_TTL_SEC=3600
SESSION_CACHE_TTL_SEC=604800

# ─── Vector DB [RECOMMENDED for semantic memory + talent search] ─────────────
QDRANT_URL=http://qdrant-host:6333
QDRANT_API_KEY=
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Observability ───────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com
# Optional OTEL packages: @opentelemetry/sdk-node @opentelemetry/exporter-trace-otlp-http

# ─── Voice (optional) ────────────────────────────────────────────────────────
WHISPER_URL=
XTTS_URL=

# ─── Object storage (optional) ───────────────────────────────────────────────
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# ─── OAuth integrations (optional) ───────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
