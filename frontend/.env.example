# Database — provider: supabase (testing) | local (docker) | aws-rds (production)
DATABASE_PROVIDER=supabase

# Supabase (testing) — Dashboard → Project Settings → Database → Connection string
# Use port 6543 + ?pgbouncer=true for DATABASE_URL (app runtime)
# Use port 5432 for DIRECT_URL (prisma db push / migrate)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Supabase API keys — Dashboard → Project Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_PROJECT_REF=

# Local PostgreSQL (docker-compose) — keep for offline dev
# DATABASE_PROVIDER=local
# DATABASE_URL=postgresql://nexusedge:nexusedge_secret@localhost:5432/nexusedge
# DIRECT_URL=postgresql://nexusedge:nexusedge_secret@localhost:5432/nexusedge

# AWS RDS (production — future)
# DATABASE_PROVIDER=aws-rds
# DATABASE_URL=postgresql://user:password@your-rds-endpoint.region.rds.amazonaws.com:5432/nexusedge
# DIRECT_URL=postgresql://user:password@your-rds-endpoint.region.rds.amazonaws.com:5432/nexusedge

# Redis / Queue
REDIS_URL=redis://localhost:6379

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production-use-openssl-rand
JWT_SECRET=change-me-in-production

# AI - ModelGateway (priority: ollama → vllm → openai/anthropic → heuristic)
MODEL_PROVIDER=ollama

# Ollama (local — https://ollama.com)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_MODEL_REASONING=deepseek-r1:8b
OLLAMA_TIMEOUT_MS=120000
OLLAMA_MAX_RETRIES=3
OLLAMA_ENABLE_THINKING=false

# Prompts (PR-2) — v1 plain text, v2 structured JSON
PROMPT_VERSION=v2

# vLLM (optional remote GPU server)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=deepseek-ai/DeepSeek-V2.5
QWEN_MODEL=qwen/Qwen2.5-72B-Instruct
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Code execution
JUDGE0_URL=http://localhost:2358
JUDGE0_API_KEY=
# Set true to require Judge0 in production (no silent regex fallback)
JUDGE0_REQUIRE=false

# Voice
WHISPER_URL=http://localhost:9000
XTTS_URL=http://localhost:8020

# Storage
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# Integrations (PR-8 OAuth)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
INTEGRATION_ENCRYPTION_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App
NEXT_PUBLIC_API_URL=http://localhost:3000/api
