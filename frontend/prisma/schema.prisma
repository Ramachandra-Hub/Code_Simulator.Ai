// ─── PR-13 Virtual Office Simulator ───────────────────────────────────────────

model VirtualCompany {
  id          String              @id @default(cuid())
  name        String
  culture     String              @default("startup")
  description String?             @db.Text
  departments VirtualDepartment[]
  sessions    OfficeSession[]
  createdAt   DateTime            @default(now())
}

model VirtualDepartment {
  id        String         @id @default(cuid())
  companyId String
  company   VirtualCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  focus     String?
  sessions  OfficeSession[]
}

model OfficeSession {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId    String
  company      VirtualCompany    @relation(fields: [companyId], references: [id])
  departmentId String?
  department   VirtualDepartment? @relation(fields: [departmentId], references: [id])
  role         String            @default("software_engineer")
  level        String            @default("junior")
  status       String            @default("active")
  startedAt    DateTime          @default(now())
  tasks        WorkTask[]
  meetings     Meeting[]
  standups     StandupReport[]
  codeReviews  CodeReview[]
  reviews      PerformanceReview[]
  promotions   PromotionAssessment[]

  @@index([userId, status])
}

model WorkTask {
  id          String        @id @default(cuid())
  sessionId   String
  session     OfficeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title       String
  type        String
  description String        @db.Text
  status      String        @default("assigned")
  priority    Int           @default(0)
  twinContext Json?
  completedAt DateTime?
  createdAt   DateTime      @default(now())

  @@index([sessionId, status])
}

model Meeting {
  id          String        @id @default(cuid())
  sessionId   String
  session     OfficeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type        String
  title       String
  agenda      Json?
  transcript  Json?
  voiceEnabled Boolean      @default(true)
  status      String        @default("scheduled")
  scheduledAt DateTime      @default(now())
  completedAt DateTime?
  scores      Json?

  @@index([sessionId, type])
}

model StandupReport {
  id           String        @id @default(cuid())
  sessionId    String
  session      OfficeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  yesterday    String        @db.Text
  today        String        @db.Text
  blockers     String?       @db.Text
  communicationScore Float   @default(0)
  ownershipScore     Float   @default(0)
  professionalismScore Float @default(0)
  feedback     String?       @db.Text
  createdAt    DateTime      @default(now())

  @@index([sessionId, createdAt])
}

model CodeReview {
  id          String        @id @default(cuid())
  sessionId   String
  session     OfficeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  code        String        @db.Text
  language    String        @default("typescript")
  reviewerAgent String      @default("senior-engineer")
  questions   Json?
  feedback    String?       @db.Text
  score       Float         @default(0)
  status      String        @default("pending")
  createdAt   DateTime      @default(now())

  @@index([sessionId])
}

model PerformanceReview {
  id              String        @id @default(cuid())
  sessionId       String
  session         OfficeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  period          String
  technical       Float
  communication   Float
  ownership       Float
  leadership      Float
  collaboration   Float
  promotionReady  Float
  summary         String?       @db.Text
  createdAt       DateTime      @default(now())

  @@index([sessionId, period])
}

model PromotionAssessment {
  id          String        @id @default(cuid())
  sessionId   String
  session     OfficeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  ready       Boolean       @default(false)
  score       Float
  gaps        Json?
  recommendation String?    @db.Text
  createdAt   DateTime      @default(now())
}

model OfficeAchievement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  category    String
  badge       String?
  metadata    Json?
  achievedAt  DateTime @default(now())

  @@index([userId, category])
}
