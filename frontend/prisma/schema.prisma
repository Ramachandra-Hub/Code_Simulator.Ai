// ─── PR-6 Self-Improving Intelligence Layer ─────────────────────────────────

model QuestionEffectiveness {
  id                 String   @id @default(cuid())
  questionKey        String
  questionText       String   @db.Text
  interviewType      String?
  timesAsked         Int      @default(0)
  timesAnswered      Int      @default(0)
  timesSkipped       Int      @default(0)
  timesAbandoned     Int      @default(0)
  followUpCount      Int      @default(0)
  followUpImproved   Int      @default(0)
  totalScore         Float    @default(0)
  totalEngagement    Float    @default(0)
  ratingImpactSum    Float    @default(0)
  ratingImpactCount  Int      @default(0)
  effectivenessScore Float    @default(50)
  lastSeenAt         DateTime?
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())

  @@unique([questionKey, interviewType])
  @@index([effectivenessScore])
  @@index([interviewType])
}

model RecommendationEffectiveness {
  id                  String   @id @default(cuid())
  titleKey            String   @unique
  title               String
  category            String?
  timesShown          Int      @default(0)
  timesAccepted       Int      @default(0)
  timesDismissed      Int      @default(0)
  timesIgnored        Int      @default(0)
  timesCompleted      Int      @default(0)
  placementDeltaSum   Float    @default(0)
  placementDeltaCount Int      @default(0)
  ratingSum           Float    @default(0)
  ratingCount         Int      @default(0)
  effectivenessScore  Float    @default(50)
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())

  @@index([effectivenessScore])
}

model RecommendationOutcome {
  id               String   @id @default(cuid())
  userId           String
  recommendationId String?
  title            String
  titleKey         String
  action           String
  placementBefore  Float?
  placementAfter   Float?
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([userId, action])
  @@index([titleKey])
  @@index([createdAt])
}

model InterviewQualityEvent {
  id           String   @id @default(cuid())
  sessionId    String
  userId       String
  event        String
  questionKey  String?
  questionText String?  @db.Text
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([sessionId])
  @@index([event, createdAt])
  @@index([questionKey])
}

model IntelligenceImprovementReport {
  id          String   @id @default(cuid())
  weekStart   DateTime @unique
  weekEnd     DateTime
  metrics     Json
  aiSummary   Json
  aiGenerated Boolean  @default(false)
  generatedAt DateTime @default(now())

  @@index([weekStart])
}

// ─── Voice Interview (PR-7) ─────────────────────────────────────────────────

model VoiceInterviewSession {
  id                 String           @id @default(cuid())
  interviewSessionId String           @unique
  interviewSession   InterviewSession @relation(fields: [interviewSessionId], references: [id], onDelete: Cascade)
  userId             String
  interviewType      InterviewType
  voiceProfile       String           @default("professional")
  sttEngine          String           @default("whisper")
  ttsEngine          String           @default("xtts")
  status             String           @default("active")
  recording          Boolean          @default(false)
  startedAt          DateTime         @default(now())
  stoppedAt          DateTime?
  transcripts        VoiceTranscript[]
  metrics            VoiceMetrics[]
  feedback           VoiceFeedback[]

  @@index([userId, startedAt])
}

model VoiceTranscript {
  id                      String                @id @default(cuid())
  voiceInterviewSessionId String
  voiceSession            VoiceInterviewSession @relation(fields: [voiceInterviewSessionId], references: [id], onDelete: Cascade)
  role                    String
  text                    String                @db.Text
  isFinal                 Boolean               @default(true)
  audioDurationMs         Int?
  createdAt               DateTime              @default(now())

  @@index([voiceInterviewSessionId, createdAt])
}

model VoiceMetrics {
  id                      String                @id @default(cuid())
  voiceInterviewSessionId String
  voiceSession            VoiceInterviewSession @relation(fields: [voiceInterviewSessionId], references: [id], onDelete: Cascade)
  turnIndex               Int                   @default(0)
  wordsPerMinute          Float?
  fillerCount             Int                   @default(0)
  pauseCount              Int                   @default(0)
  confidenceEstimate      Float?
  communicationScore      Float?
  clarityScore            Float?
  speakingPace            String?
  metadata                Json?
  createdAt               DateTime              @default(now())

  @@index([voiceInterviewSessionId, turnIndex])
}

model VoiceFeedback {
  id                      String                @id @default(cuid())
  voiceInterviewSessionId String
  voiceSession            VoiceInterviewSession @relation(fields: [voiceInterviewSessionId], references: [id], onDelete: Cascade)
  summary                 String                @db.Text
  recommendations         String[]              @default([])
  strengths               String[]              @default([])
  improvements            String[]              @default([])
  source                  String                @default("voice-analysis")
  createdAt               DateTime              @default(now())

  @@index([voiceInterviewSessionId])
}

model SystemError {
  id         String   @id @default(cuid())
  source     String
  route      String?
  method     String?
  statusCode Int?
  message    String   @db.Text
  stack      String?  @db.Text
  metadata   Json?
  userId     String?
  createdAt  DateTime @default(now())

  @@index([source, createdAt])
  @@index([route, createdAt])
  @@index([createdAt])
}

// ─── PR-10 Talent Intelligence Platform ─────────────────────────────────────

model RecruiterCompany {
  id         String          @id @default(cuid())
  name       String
  industry   String?
  website    String?
  metadata   Json?
  createdAt  DateTime        @default(now())
  recruiters RecruiterUser[]
  jobs       JobDescription[]
}

model RecruiterUser {
  id         String              @id @default(cuid())
  userId     String              @unique
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId  String?
  company    RecruiterCompany?   @relation(fields: [companyId], references: [id])
  title      String?
  createdAt  DateTime            @default(now())
  shortlists CandidateShortlist[]
  searches   RecruiterSearch[]
  jobs       JobDescription[]    @relation("JobRecruiter")
}

model JobDescription {
  id          String           @id @default(cuid())
  companyId   String?
  company     RecruiterCompany?  @relation(fields: [companyId], references: [id])
  recruiterId String?
  recruiter   RecruiterUser?   @relation("JobRecruiter", fields: [recruiterId], references: [id])
  title       String
  description String           @db.Text
  skills      String[]         @default([])
  location    String?
  parsed      Json?
  status      String           @default("open")
  matches     TalentMatch[]
  decisions   HiringDecision[]
  shortlists  CandidateShortlist[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model CandidateShortlist {
  id            String          @id @default(cuid())
  recruiterId   String
  recruiter     RecruiterUser   @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  candidateId   String
  candidate     User            @relation("ShortlistedCandidate", fields: [candidateId], references: [id], onDelete: Cascade)
  jobId         String?
  job           JobDescription? @relation(fields: [jobId], references: [id])
  status        String          @default("shortlisted")
  notes         String?         @db.Text
  interviewPlan Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([recruiterId, candidateId, jobId])
}

model TalentMatch {
  id               String         @id @default(cuid())
  jobId            String
  job              JobDescription @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId      String
  candidate        User           @relation("TalentMatchCandidate", fields: [candidateId], references: [id], onDelete: Cascade)
  technicalFit     Float
  codingFit        Float
  communicationFit Float
  leadershipFit    Float
  professionalFit  Float
  overallMatch     Float
  ranking          Int?
  factors          Json?
  createdAt        DateTime       @default(now())

  @@unique([jobId, candidateId])
}

model HiringDecision {
  id          String          @id @default(cuid())
  jobId       String?
  job         JobDescription? @relation(fields: [jobId], references: [id])
  candidateId String
  candidate   User            @relation("HiringDecisionCandidate", fields: [candidateId], references: [id], onDelete: Cascade)
  recruiterId String?
  decision    String
  confidence  Float
  reasoning   String?         @db.Text
  data        Json?
  createdAt   DateTime        @default(now())
}

model GrowthPotentialSnapshot {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score      Float
  tier       String
  factors    Json?
  computedAt DateTime @default(now())
}

model RecruiterSearch {
  id          String        @id @default(cuid())
  recruiterId String
  recruiter   RecruiterUser @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  query       String
  filters     Json?
  results     Json?
  createdAt   DateTime      @default(now())
}

model TalentRadarSnapshot {
  id           String   @id @default(cuid())
  category     String
  title        String
  candidateIds String[] @default([])
  scores       Json?
  computedAt   DateTime @default(now())
}

